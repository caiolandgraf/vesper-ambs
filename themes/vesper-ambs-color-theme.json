  "semanticTokenColors": {
    // "property": "#A78BFA",
    "property.readonly": "#A78BFA",
    // "property.defaultLibrary": "#A78BFA",
    // "property.readonly.defaultLibrary": "#A78BFA"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment"
      ],
      "settings": {
        "foreground": "#6B7280"
      }
    },
    {
      "name": "Comment Punctuation",
      "scope": [
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6B728080"
      }
    },
    {
      "name": "Import/Export",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from"
      ],
      "settings": {
        "foreground": "#f871c7",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Control Keywords",
      "scope": [
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.conditional",
        "keyword.control.loop"
      ],
      "settings": {
        "foreground": "#f871c7"
      }
    },
    {
      "name": "Variable Declaration",
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#7DD3FC"
        // "foreground": "#8b86ef"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#A78BFA"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string"
      ],
      "settings": {
        // "foreground": "#86EFAC"
        "foreground": "#7DD3FC"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#F9A8D4"
      }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#C4B5FD"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "identifier"
      ],
      "settings": {
        "foreground": "#E5E7EB"
      }
    },
    {
      "name": "Booleans & Null",
      "scope": [
        "constant.language.boolean",
        "constant.language",
        "constant.language.null"
      ],
      "settings": {
        "foreground": "#F9A8D4"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#A0A0A0"
      }
    },
    {
      "name": "HTML Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag",
        "meta.tag entity.name.tag"
      ],
      "settings": {
        "foreground": "#A78BFA"
      }
    },
    {
      "name": "CSS Classes",
      "scope": [
        "entity.other.attribute-name.class",
        "entity.other.class",
        "support.type.property-name.css"
      ],
      "settings": {
        "foreground": "#C4B5FD"
      }
    },
    {
      "name": "CSS Properties",
      "scope": [
        "support.type.property-name.css",
        "meta.property-name.css"
      ],
      "settings": {
        "foreground": "#7DD3FC"
      }
    },
    {
      "name": "Operators & Punctuation",
      "scope": [
        "punctuation",
        "operator"
      ],
      "settings": {
        "foreground": "#9CA3AF"
      }
    },
  ]
}